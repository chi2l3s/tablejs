{
  "name": "@table-js/platform",
  "version": "0.0.4",
  "description": "Table.js platform adapters and build tools for Smart TV",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "table": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "smart-tv",
    "tizen",
    "webos",
    "android-tv",
    "build-tool",
    "vite"
  ],
  "author": "Table.js Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tablejs/tablejs"
  },
  "dependencies": {
    "vite": "^6.4.1",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.3.4",
    "archiver": "^7.0.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@table-js/tsconfig": "workspace:*",
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
