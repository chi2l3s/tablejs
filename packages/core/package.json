{
  "name": "@table-js/core",
  "version": "0.0.4",
  "description": "Table.js core runtime - router, focus, navigation for Smart TV",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "smart-tv",
    "tizen",
    "webos",
    "android-tv",
    "react",
    "focus",
    "router"
  ],
  "author": "Table.js Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tablejs/tablejs"
  },
  "devDependencies": {
    "@table-js/tsconfig": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
