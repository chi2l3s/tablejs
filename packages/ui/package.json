{
  "name": "@table-js/ui",
  "version": "0.0.4",
  "description": "Table.js UI components for Smart TV",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "smart-tv",
    "ui",
    "components",
    "react",
    "tizen",
    "webos"
  ],
  "author": "Table.js Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tablejs/tablejs"
  },
  "devDependencies": {
    "@table-js/tsconfig": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@table-js/core": "workspace:^",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
